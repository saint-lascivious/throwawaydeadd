################################################################################
# perform_service_action        - Run service action via detected init system
#
# DESCRIPTION:
#   Attempts init systems in INIT_SYSTEM_ORDER:
#   service systemctl, rc-service, sv, launchctl
#
# USAGE:
#   perform_service_action <service> <action>
#
# USES:
#   log_handler()
#
# EXIT CODES:
#   0 - Success
#   1 - Failure or unsupported init system
################################################################################
perform_service_action() {
    _SERVICE="$1"
    _ACTION="$2"

    _ORDER="${INIT_SYSTEM_ORDER:-service systemctl rc-service sv launchctl}"
    _ORDER=$(printf "%s" "$_ORDER" | tr ',' ' ')

    for _INIT in $_ORDER; do
        case "$_INIT" in
            service)
                if command -v service >/dev/null 2>&1; then
                    log_handler 3 "Using service"
                    service "$_SERVICE" "$_ACTION"
                    return $?
                fi
                ;;
            systemctl)
                if command -v systemctl >/dev/null 2>&1; then
                    log_handler 3 "Using systemctl"
                    systemctl "$_ACTION" "$_SERVICE"
                    return $?
                fi
                ;;
            rc-service)
                if command -v rc-service >/dev/null 2>&1; then
                    log_handler 3 "Using rc-service"
                    rc-service "$_SERVICE" "$_ACTION"
                    return $?
                fi
                ;;
            sv)
                if command -v sv >/dev/null 2>&1; then
                    log_handler 3 "Using sv (runit)"
                    sv "$_ACTION" "$_SERVICE"
                    return $?
                fi
                ;;
            launchctl)
                if command -v launchctl >/dev/null 2>&1; then
                    log_handler 3 "Using launchctl"
                    case "$_ACTION" in
                        start)   launchctl start "$_SERVICE" ;;
                        stop)    launchctl stop "$_SERVICE" ;;
                        restart) launchctl kickstart -k "system/$_SERVICE" ;;
                        reload)  launchctl kickstart -k "system/$_SERVICE" ;;
                        *)       return 1 ;;
                    esac
                    return $?
                fi
                ;;
            *)
                log_handler 3 "Unknown init system in order list: $_INIT"
                ;;
        esac
    done

    log_handler 1 "No supported init system found (service|systemctl|rc-service|sv|launchctl)"
    return 1
}

SERVICE=""

                    exit 0
                else
                    exit 1
                fi
                ;;
                "")
                    printf "[ERROR]: The 'show' command requires an argument (w or c)\n" >&2
                    exit 2
                    ;;
                *)
                    printf "[ERROR]: Invalid argument for 'show' %s (expected: w or c)\n" "$MODE" >&2
                    exit 2
                    ;;
        esac
        ;;
esac

if [ -n "$SERVICE" ]; then
    case "$SERVICE" in
        *[!A-Za-z0-9_.-]*)
            log_handler 1 "Invalid service name '$SERVICE' (allowed: A-Za-z0-9_.-)"
            exit 2
            ;;
    esac
fi

if [ -z "$CONFIG_FILE" ]; then
    SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
    if [ -n "$SERVICE" ]; then
        CONFIG_FILE="$SCRIPT_DIR/${SERVICE}.conf"
    else
        CONFIG_FILE="$SCRIPT_DIR/throwawaydeadd.conf"
    fi
fi

if [ -f "$CONFIG_FILE" ]; then
    if [ -r "$CONFIG_FILE" ]; then
        if ! check_config_permissions "$CONFIG_FILE"; then
            exit 3
        fi
        log_handler 2 "Sourcing config file $CONFIG_FILE"
        if ! awk '
            /^[[:space:]]*$/ { next }
            /^[[:space:]]*#/ { next }
            /^[A-Z_][A-Z0-9_]*=/ { next }
            { print NR ": " $0; exit 1 }
        ' "$CONFIG_FILE"; then
            log_handler 1 "Config file contains invalid lines (MUST be uppercase VAR=val format)"
            exit 3
        fi
        set -a
        # shellcheck disable=SC1090
        . "$CONFIG_FILE"
        set +a
    else
        log_handler 1 "Config file is not readable $CONFIG_FILE"
        exit 3
    fi

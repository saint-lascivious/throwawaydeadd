THROWAWAYDEADD_VERSION="0.1.0-master"

VERBOSITY="${THROWAWAYDEADD_VERBOSITY:-0}"

if command -v logger >/dev/null 2>&1; then
    readonly USE_LOGGER=true
else
    readonly USE_LOGGER=false
fi

################################################################################
# log_handler                   - Log a message at a given verbosity
#
# DESCRIPTION:
#   Logs to syslog via logger when available, or to stderr otherwise.
#   Messages are prefixed with a severity level (ERROR, INFO, DEBUG) based on
#   the provided log level.
#
# USAGE:
#   log_handler <level> <message...>
#
# ARGUMENTS:
#   level                       - 1=error, 2=info, 3=debug
#   message...                  - Message to log
################################################################################
log_handler() {
    _VERBOSITY="$1"
    shift

    case "$_VERBOSITY" in
        1) _LOG_PREFIX="ERROR" ;;
        2) _LOG_PREFIX="INFO" ;;
        3) _LOG_PREFIX="DEBUG" ;;
        *)
            printf "[ERROR]: Invalid log level '%s'\n" "$_VERBOSITY" >&2
            return 1
            ;;
    esac

    case "$VERBOSITY" in
        0|1|2|3) _EFFECTIVE_VERBOSITY="$VERBOSITY" ;;
        *) _EFFECTIVE_VERBOSITY=0 ;;
    esac

    if [ "$_EFFECTIVE_VERBOSITY" -ge "$_VERBOSITY" ]; then
        if [ "$USE_LOGGER" = true ]; then
            logger -t throwawaydeadd "[$_LOG_PREFIX]: $*"
        else
            printf "[%s]: %s\n" "$_LOG_PREFIX" "$*" >&2
        fi
    fi
}

################################################################################
# upper_to_lower                - Convert a string to lowercase
#
# DESCRIPTION:
#   Converts an uppercase or mixed case input string to lowercase.
#
# USAGE:
#   upper_to_lower <string>
################################################################################
upper_to_lower() {
    printf "%s" "$1" | tr '[:upper:]' '[:lower:]'
}

################################################################################
# check_is_true                 - Test for boolean truthy values
#
# DESCRIPTION:
#   Case insensitive true/false test.
#   Returns success (0) for yes|true|1
#   Returns failure (1) for no|false|0|*
#
# USAGE:
#   check_is_true <value>
#
# USES:
#   upper_to_lower()
#   log_handler()
#
################################################################################
check_is_true() {
    case "$(upper_to_lower "$1")" in
        yes|true|1) return 0 ;;
        no|false|0) return 1 ;;
        *)
            log_handler 1 "Invalid boolean value $1 (expected yes|true|1|no|false|0)"
            return 1
            ;;
    esac
}

################################################################################
# check_config_permissions      - Verify config file permissions and ownership
#
# DESCRIPTION:
#   Ensures config file is not world-writable or group-writable, and is owned
#   by root or the current user to prevent unauthorized modification.
#
# USAGE:
#   check_config_permissions <filepath>
#
# USES:
#   log_handler()
#
# EXIT CODES:
#   0 - Permissions acceptable
#   1 - Permissions too permissive or ownership issue
################################################################################
check_config_permissions() {
    _CONFIG_PATH="$1"

    if stat --version >/dev/null 2>&1; then
        _CONFIG_PERMISSIONS=$(stat -c '%a' "$_CONFIG_PATH" 2>/dev/null)
        _CONFIG_OWNERSHIP=$(stat -c '%U' "$_CONFIG_PATH" 2>/dev/null)
    else
        _CONFIG_PERMISSIONS=$(stat -f '%Lp' "$_CONFIG_PATH" 2>/dev/null)
        _CONFIG_OWNERSHIP=$(stat -f '%Su' "$_CONFIG_PATH" 2>/dev/null)
    fi

    if [ -z "$_CONFIG_PERMISSIONS" ] || [ -z "$_CONFIG_OWNERSHIP" ]; then
        log_handler 1 "Cannot determine permissions/ownership of $_CONFIG_PATH"
        return 1
    fi

    _WORLD_DIGIT=$(printf "%s" "$_CONFIG_PERMISSIONS" | tail -c 2 | head -c 1)
    _GROUP_DIGIT=$(printf "%s" "$_CONFIG_PERMISSIONS" | tail -c 3 | head -c 1)

    case "$_GROUP_DIGIT$_WORLD_DIGIT" in
        *[2367]*)
            log_handler 1 "Config file is world or group writable: $_CONFIG_PERMISSIONS"
            return 1
            ;;
    esac

    _CURRENT_USER=$(id -un 2>/dev/null || whoami)
    if [ "$_CONFIG_OWNERSHIP" != "root" ] && [ "$_CONFIG_OWNERSHIP" != "$_CURRENT_USER" ]; then
        log_handler 1 "Config file not owned by root or current user: $_CONFIG_OWNERSHIP"
        return 1
    fi

    log_handler 3 "Config permissions verified: owner=$_CONFIG_OWNERSHIP, mode=$_CONFIG_PERMISSIONS"
    return 0
}

################################################################################
# get_state_directory           - Get the state directory path
#
# DESCRIPTION:
#   Returns the preferred state directory path for cache files.
#   Prioritizes RAM-based filesystems to avoid disk I/O overhead.
#   Order: /dev/shm > /tmp > /run > fallback to current directory
#
# USAGE:
#   get_state_directory
#
# USES:
#   log_handler()
################################################################################
get_state_directory() {
    _BASE_DIR="${STATE_CACHE_DIR:-}"

    if [ -n "$_BASE_DIR" ]; then
        if [ -d "$_BASE_DIR" ] && [ -w "$_BASE_DIR" ]; then
            printf "%s/throwawaydeadd" "$_BASE_DIR"
            return 0
        else
            log_handler 2 "Configured STATE_CACHE_DIR $_BASE_DIR is not accessible"
        fi
    fi

    for _DIR in "/dev/shm" "/tmp" "/run"; do
        if [ -d "$_DIR" ] && [ -w "$_DIR" ]; then
            printf "%s/throwawaydeadd" "$_DIR"
            return 0
        fi
    done

    log_handler 2 "No writable tmpfs found, using ./throwawaydeadd_cache instead"
    printf "./throwawaydeadd_cache"
    return 0
}

################################################################################
# get_state_file_path           - Get the state file path for a service
#
# DESCRIPTION:
#   Returns the full path to the state file for a given service.
#   State files are stored in the state directory as throwawaydeadd_<service>.state
#
# USAGE:
#   get_state_file_path <service>
#
# USES:
#   get_state_directory()
################################################################################
get_state_file_path() {
    _SERVICE="$1"
    _STATE_DIR=$(get_state_directory)
    if [ -z "$_STATE_DIR" ]; then
        log_handler 1 "Failed to determine state directory"
        return 1
    fi
    printf "%s/throwawaydeadd_%s.state" "$_STATE_DIR" "$_SERVICE"
    return 0
}

################################################################################
# check_cached_state            - Check cached service state with timeout
#
# DESCRIPTION:
#   Returns cached service state if timeout hasn't expired.
#   Cache state format: "timestamp:status" (status is 0 or 1)
#
# USAGE:
#   check_cached_state <service> <timeout_seconds>
#
# USES:
#   get_state_file_path()
#   log_handler()
#
# EXIT CODES:
#   0 - Service is running (cached)
#   1 - Service not running or cache invalid
#   2 - No cached state available
################################################################################
check_cached_state() {
    _SERVICE="$1"
    _TIMEOUT="${2:-${STATE_CACHE_TIMEOUT:-30}}"
    _STATE_FILE=$(get_state_file_path "$_SERVICE")

    case "$_TIMEOUT" in
        ''|*[!0-9]*)
            log_handler 1 "Invalid cache timeout for $_SERVICE: $_TIMEOUT"
            return 2
            ;;
    esac

    if [ "$_TIMEOUT" -le 0 ]; then
        log_handler 3 "State caching disabled"
        return 2
    fi

    if [ ! -f "$_STATE_FILE" ]; then
        log_handler 3 "No cached state for $_SERVICE"
        return 2
    fi

    _CACHED_DATA=$(cat "$_STATE_FILE" 2>/dev/null)
    _CACHED_TIME=$(printf "%s" "$_CACHED_DATA" | cut -d: -f1)
    _CACHED_STATUS=$(printf "%s" "$_CACHED_DATA" | cut -d: -f2)

    if [ -z "$_CACHED_TIME" ] || [ -z "$_CACHED_STATUS" ]; then
        log_handler 3 "Corrupted state file for $_SERVICE"
        return 2
    fi

    case "$_CACHED_TIME" in
        ''|*[!0-9]*)
            log_handler 3 "Invalid cached timestamp for $_SERVICE: $_CACHED_TIME"
            return 2
            ;;
    esac

    case "$_CACHED_STATUS" in
        0|1) ;;
        *)
            log_handler 3 "Invalid cached status for $_SERVICE: $_CACHED_STATUS"
            return 2
            ;;
    esac

    _CURRENT_TIME=$(date +%s 2>/dev/null)

    if [ -z "$_CURRENT_TIME" ]; then
        log_handler 3 "Cannot determine current time"
        return 2
    fi

    _AGE=$((_CURRENT_TIME - _CACHED_TIME))

    if [ "$_AGE" -lt 0 ] || [ "$_AGE" -gt "$_TIMEOUT" ]; then
        log_handler 3 "Cached state expired for $_SERVICE (age: $_AGE seconds)"
        return 2
    fi

    log_handler 3 "Using cached state for $_SERVICE (age: $_AGE seconds, status: $_CACHED_STATUS)"
    return "$_CACHED_STATUS"
}

################################################################################
# update_state_file             - Update cached service state
#
# DESCRIPTION:
#   Writes current timestamp and service status to state file.
#   Creates state directory if it doesn't exist.
#
# USAGE:
#   update_state_file <service> <status>
#
# USES:
#   get_state_file_path()
#   get_state_directory()
#   log_handler()
#
# ARGUMENTS:
#   service                     - Service name
#   status                      - 0 (running) or 1 (not running)
################################################################################
update_state_file() {
    _SERVICE="$1"
    _STATUS="$2"
    _STATE_FILE=$(get_state_file_path "$_SERVICE")
    _STATE_DIR=$(get_state_directory)

    if [ ! -d "$_STATE_DIR" ]; then
        if ! mkdir -p "$_STATE_DIR" 2>/dev/null; then
            log_handler 3 "Cannot create state directory $_STATE_DIR"
            return 1
        fi
    fi

    _CURRENT_TIME=$(date +%s 2>/dev/null)
    if [ -z "$_CURRENT_TIME" ]; then
        log_handler 3 "Cannot determine current time"
        return 1
    fi

    printf "%s:%s" "$_CURRENT_TIME" "$_STATUS" > "$_STATE_FILE" 2>/dev/null || {
        log_handler 3 "Failed to write state file $_STATE_FILE"
        return 1
    }

    log_handler 3 "Updated state file for $_SERVICE: status=$_STATUS"
    return 0
}

################################################################################
# cleanup_state_files           - Remove stale state cache files
#
# DESCRIPTION:
#   Deletes state files older than the specified timeout to prevent
#   accumulation of stale cache entries.
#
# USAGE:
#   cleanup_state_files <max_age_seconds>
#
# USES:
#   get_state_directory()
#   log_handler()
################################################################################
cleanup_state_files() {
    _MAX_AGE="${1:-300}"
    _STATE_DIR=$(get_state_directory)

    case "$_MAX_AGE" in
        ''|*[!0-9]*)
            log_handler 1 "Invalid cleanup max age: $_MAX_AGE"
            return 2
            ;;
    esac

    if [ ! -d "$_STATE_DIR" ]; then
        log_handler 3 "State directory does not exist, skipping cleanup"
        return 0
    fi

    _CURRENT_TIME=$(date +%s 2>/dev/null)
    if [ -z "$_CURRENT_TIME" ]; then
        log_handler 1 "Cannot determine current time, cleanup failed"
        return 1
    fi

    _CLEANED=0
    _FAILED=0

    for _STATE_FILE in "$_STATE_DIR"/throwawaydeadd_*.state; do
        if [ ! -f "$_STATE_FILE" ]; then
            continue
        fi

        if ! _CACHED_TIME=$(cut -d: -f1 "$_STATE_FILE" 2>/dev/null); then
            _FAILED=$((_FAILED + 1))
            log_handler 1 "Failed to read state file $(basename "$_STATE_FILE")"
            continue
        fi

        case "$_CACHED_TIME" in
            ''|*[!0-9]*)
                log_handler 3 "Skipping malformed state file $(basename "$_STATE_FILE")"
                continue
                ;;
        esac

        _AGE=$((_CURRENT_TIME - _CACHED_TIME))
        if [ "$_AGE" -gt "$_MAX_AGE" ]; then
            if rm -f "$_STATE_FILE" 2>/dev/null; then
                _CLEANED=$((_CLEANED + 1))
                log_handler 3 "Cleaned state file $(basename "$_STATE_FILE") (age: $_AGE seconds)"
            else
                _FAILED=$((_FAILED + 1))
                log_handler 1 "Failed to remove stale state file $(basename "$_STATE_FILE")"
            fi
        fi
    done

    if [ "$_CLEANED" -gt 0 ]; then
        log_handler 3 "Cleaned $_CLEANED stale state file(s)"
    fi

    if [ "$_FAILED" -gt 0 ]; then
        log_handler 1 "Cleanup completed with $_FAILED error(s)"
        return 1
    fi

    return 0
}

################################################################################
# flush_state_files             - Remove all state cache files
#
# DESCRIPTION:
#   Deletes all state cache files regardless of age to completely reset
#   the service state cache.
#
# USAGE:
#   flush_state_files
#
# USES:
#   get_state_directory()
#   log_handler()
################################################################################
flush_state_files() {
    _STATE_DIR=$(get_state_directory)

    if [ ! -d "$_STATE_DIR" ]; then
        log_handler 2 "State directory does not exist"
        return 0
    fi

    _FLUSHED=0
    for _STATE_FILE in "$_STATE_DIR"/throwawaydeadd_*.state; do
        if [ ! -f "$_STATE_FILE" ]; then
            continue
        fi

        if rm -f "$_STATE_FILE" 2>/dev/null; then
            _FLUSHED=$((_FLUSHED + 1))
            log_handler 3 "Flushed state file $(basename "$_STATE_FILE")"
        fi
    done

    if [ "$_FLUSHED" -gt 0 ]; then
        log_handler 2 "Flushed $_FLUSHED state file(s)"
    else
        log_handler 3 "No state files to flush"
    fi

    return 0
}

################################################################################
# check_write_access            - Check if we can write to a path
#
# DESCRIPTION:
#   Determines if the current user has write access to a target path.
#   If the path doesn't exist, checks the parent directory.
#
# USAGE:
#   check_write_access <path>
#
# EXIT CODES:
#   0 - Write access available
#   1 - No write access
################################################################################
check_write_access() {
    _PATH="$1"

    if [ -e "$_PATH" ]; then
        if [ -w "$_PATH" ]; then
            return 0
        else
            return 1
        fi
    fi

    _PARENT=$(dirname "$_PATH")
    if [ -w "$_PARENT" ]; then
        return 0
    fi

    return 1
}

################################################################################
# elevate_privileges            - Attempt privilege elevation via sudo
#
# DESCRIPTION:
#   Attempts to elevate privileges using sudo if available and needed.
#   Returns success if already running as root or sudo elevation succeeds.
#   Uses POSIX-compliant sudo syntax.
#
# USAGE:
#   elevate_privileges
#
# USES:
#   log_handler()
#
# EXIT CODES:
#   0 - Privileges sufficient (root or sudo available)
#   1 - Privilege elevation failed
################################################################################
elevate_privileges() {
    if [ "$(id -u 2>/dev/null)" -eq 0 ]; then
        log_handler 3 "Already running as root"
        return 0
    fi

    if ! command -v sudo >/dev/null 2>&1; then
        log_handler 1 "sudo not available and not running as root"
        return 1
    fi

    log_handler 2 "Attempting privilege elevation with sudo"
    if sudo -v 2>/dev/null; then
        log_handler 3 "sudo credentials validated"
        return 0
    else
        log_handler 1 "sudo privilege elevation failed"
        return 1
    fi
}

################################################################################
# run_with_sudo                 - Execute command with sudo if needed
#
# DESCRIPTION:
#   Executes a command with sudo if the current user is not root.
#   Uses POSIX-compliant sudo syntax.
#
# USAGE:
#   run_with_sudo <command> [args...]
#
# USES:
#   log_handler()
#
# EXIT CODES:
#   Exit code of the executed command
################################################################################
run_with_sudo() {
    if [ "$(id -u 2>/dev/null)" -eq 0 ]; then
        "$@"
        return $?
    fi

    if command -v sudo >/dev/null 2>&1; then
        sudo "$@"
        return $?
    fi

    log_handler 1 "Cannot elevate privileges: sudo not available"
    return 1
}

################################################################################
# install_script                - Install throwawaydeadd to system
#
# DESCRIPTION:
#   Installs throwawaydeadd to a target location with appropriate permissions.
#   Default installation path: /usr/local/bin/keepalived/throwawaydeadd
#   Automatically attempts privilege elevation via sudo if needed.
#
# USAGE:
#   install_script [<target_path>]
#
# USES:
#   log_handler()
#   check_write_access()
#   elevate_privileges()
#   run_with_sudo()
#
# ARGUMENTS:
#   target_path                 - Installation path (default:
#                                 /usr/local/bin/keepalived/throwawaydeadd)
#                                 Can be a directory (uses default name) or
#                                 a full file path
#
# EXIT CODES:
#   0 - Installation successful
#   1 - Installation failed
################################################################################
install_script() {
    _TARGET="${1:-/usr/local/bin/keepalived/throwawaydeadd}"
    _SCRIPT_PATH="$0"

    if [ ! -f "$_SCRIPT_PATH" ]; then
        log_handler 1 "Cannot locate script to install: $_SCRIPT_PATH"
        return 1
    fi

    if [ -d "$_TARGET" ]; then
        _TARGET="$_TARGET/throwawaydeadd"
    fi

    _TARGET_DIR=$(dirname "$_TARGET")

    if ! check_write_access "$_TARGET_DIR"; then
        log_handler 2 "Insufficient permissions for $_TARGET_DIR, attempting elevation"
        if ! elevate_privileges; then
            log_handler 1 "Cannot install to $_TARGET_DIR (permission denied)"
            return 1
        fi
    fi

    if [ ! -d "$_TARGET_DIR" ]; then
        log_handler 2 "Creating installation directory $_TARGET_DIR"
        if ! run_with_sudo mkdir -p "$_TARGET_DIR" 2>/dev/null; then
            log_handler 1 "Failed to create directory $_TARGET_DIR"
            return 1
        fi
    fi

    if ! run_with_sudo cp "$_SCRIPT_PATH" "$_TARGET" 2>/dev/null; then
        log_handler 1 "Failed to copy script to $_TARGET"
        return 1
    fi

    if ! run_with_sudo chmod 755 "$_TARGET" 2>/dev/null; then
        log_handler 1 "Failed to set executable permissions on $_TARGET"
        return 1
    fi

    log_handler 2 "Installation successful: $_TARGET"
    return 0
}

################################################################################
# uninstall_script              - Uninstall throwawaydeadd from system
#
# DESCRIPTION:
#   Removes throwawaydeadd installation from the system.
#   Removes the installation directory if empty after deletion.
#   Automatically attempts privilege elevation via sudo if needed.
#
# USAGE:
#   uninstall_script [<target_path>]
#
# USES:
#   log_handler()
#   check_write_access()
#   elevate_privileges()
#   run_with_sudo()
#
# ARGUMENTS:
#   target_path                 - Installation path to remove (default:
#                                 /usr/local/bin/keepalived/throwawaydeadd)
#
# EXIT CODES:
#   0 - Uninstallation successful or file not found
#   1 - Uninstallation failed
################################################################################
uninstall_script() {
    _TARGET="${1:-/usr/local/bin/keepalived/throwawaydeadd}"
    _TARGET_DIR=$(dirname "$_TARGET")

    if [ ! -f "$_TARGET" ]; then
        log_handler 2 "Installation not found at $_TARGET"
        return 0
    fi

    if ! check_write_access "$_TARGET"; then
        log_handler 2 "Insufficient permissions for $_TARGET, attempting elevation"
        if ! elevate_privileges; then
            log_handler 1 "Cannot uninstall from $_TARGET (permission denied)"
            return 1
        fi
    fi

    if ! run_with_sudo rm -f "$_TARGET" 2>/dev/null; then
        log_handler 1 "Failed to remove $_TARGET"
        return 1
    fi

    log_handler 2 "Uninstalled: $_TARGET"

    if [ -d "$_TARGET_DIR" ]; then
        if ! run_with_sudo rmdir "$_TARGET_DIR" 2>/dev/null; then
            log_handler 3 "Installation directory not empty, leaving: $_TARGET_DIR"
        else
            log_handler 3 "Removed empty installation directory: $_TARGET_DIR"
        fi
    fi

    return 0
}

################################################################################
# display_paged                 - Display text with pager if available
#
# DESCRIPTION:
#   Pipes input to less or more if terminal is interactive, otherwise prints
#   directly. Gracefully falls back if pager is unavailable.
#
# USAGE:
#   display_paged < file
#   command | display_paged
#
# EXIT CODES:
#   0 - Display successful
#   1 - Display failed (pager error)
################################################################################
display_paged() {
    if [ -t 1 ]; then
        if command -v less >/dev/null 2>&1; then
            less -RF
            return $?
        elif command -v more >/dev/null 2>&1; then
            more
            return $?
        else
            cat
            return $?
        fi
    else
        cat
        return $?
    fi
}


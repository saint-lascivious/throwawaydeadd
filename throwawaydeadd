        exit $?
        ;;
    install)
        install_script "$MODE"
        exit $?
        ;;
    uninstall)
        uninstall_script "$MODE"
        exit $?
        ;;
    show)
        case "$MODE" in
            w) 
                if show_warranty_information; then
                    exit 0
                else
                    exit 1
                fi
                ;;
            c) 

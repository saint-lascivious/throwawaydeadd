        v|-v|version|--version)
            SERVICE="version"
            shift
            continue
            ;;
        s|-s|show|--show)
            SERVICE="show"
            case "${2:-}" in
                w|-w|warranty|--warranty)
                    MODE="w"
                    shift 2
                    ;;
                c|-c|conditions|--conditions)
                    MODE="c"
                    shift 2
                    ;;
                "")
                    MODE=""
                    shift
                    ;;
                *)
                    MODE="$2"
                    shift 2
                    ;;
            esac
            continue
            ;;
        c|-c|config|--config)
            if [ -z "$2" ]; then
                log_handler 1 "The $1 option requires a file path argument"
                exit 2
            fi
            CONFIG_FILE="$2"
            CONFIG_EXPLICIT=true
            shift 2
            continue
            ;;
        f|-f|flush|--flush)
            SERVICE="flush"
            shift
            continue
            ;;
        i|-i|install|--install)
            SERVICE="install"
            if [ -n "$2" ] && [ "${2#-}" = "$2" ]; then
                MODE="$2"
                shift 2
            else
                MODE=""
                shift
            fi
            continue
            ;;
        u|-u|uninstall|--uninstall)
            SERVICE="uninstall"
            if [ -n "$2" ] && [ "${2#-}" = "$2" ]; then
                MODE="$2"
                shift 2
            else
                MODE=""
                shift
            fi
            continue
            ;;
        -*)
            log_handler 1 "Unknown option $1"
            exit 2
            ;;
        *)
            case "$ARGUMENT_INDEX" in
                0) SERVICE="$1" ;;
                1) MODE="$1" ;;
                2) TYPE="$1" ;;
                3) NAME="$1" ;;
                4) STATE="$1" ;;
                5) PRIORITY="$1" ;;
            esac
            ARGUMENT_INDEX=$((ARGUMENT_INDEX + 1))
            shift
            ;;
    esac
done


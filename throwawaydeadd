        _RED='\033[31m'
        _ORANGE='\033[38;5;208m'
        _YELLOW='\033[33m'
        _GREEN='\033[32m'
        _BLUE='\033[34m'
        _VIOLET='\033[35m'
        _RESET='\033[0m'

        printf "%b" \
            "${_RED}     _   _                                            _             _    _ \n" \
            "${_ORANGE}    | |_| |_  _ _ _____ __ ____ ___ __ ____ _ _  _ __| |___ __ _ __| |__| |\n" \
            "${_YELLOW}    |  _| ' \\| '_/ _ \\ V  V / _\` \\ V  V / _\` | || / _\` / -_) _\` / _\` / _\` |\n" \
            "${_GREEN}     \\__|_||_|_| \\___/\\_/\\_/\\__,_|\\_/\\_/\\__,_|\\_, \\__,_\\___\\__,_\\__,_\\__,_|\n" \
            "${_BLUE}                                              |__/                             \n\n" \
            "${_VIOLET}  throwawaydeadd                - An oddly complex VRRP check/notify script${_RESET}\n" \
            "${_RESET}"
    else
        cat << 'EOF'
     _   _                                            _             _    _ 
    | |_| |_  _ _ _____ __ ____ ___ __ ____ _ _  _ __| |___ __ _ __| |__| |

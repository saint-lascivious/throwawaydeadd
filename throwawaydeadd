case "$VERBOSITY" in
    0|1|2|3) ;;
    *)
        printf "[ERROR]: Invalid VERBOSITY '%s', defaulting to 0\n" "$VERBOSITY" >&2
        VERBOSITY=0
        ;;
esac
readonly VERBOSITY

INIT_SYSTEM_ORDER="${INIT_SYSTEM_ORDER:-service,systemctl,rc-service,sv,launchctl}"
readonly INIT_SYSTEM_ORDER

STATE_CACHE_TIMEOUT="${STATE_CACHE_TIMEOUT:-30}"
case "$STATE_CACHE_TIMEOUT" in
    ''|*[!0-9]*)
        printf "[ERROR]: Invalid STATE_CACHE_TIMEOUT '%s', defaulting to 30\n" "$STATE_CACHE_TIMEOUT" >&2
        STATE_CACHE_TIMEOUT=30
        ;;
esac
readonly STATE_CACHE_TIMEOUT

STATE_CACHE_CLEANUP="${STATE_CACHE_CLEANUP:-300}"
case "$STATE_CACHE_CLEANUP" in
    ''|*[!0-9]*)
        printf "[ERROR]: Invalid STATE_CACHE_CLEANUP '%s', defaulting to 300\n" "$STATE_CACHE_CLEANUP" >&2
        STATE_CACHE_CLEANUP=300
        ;;
esac
readonly STATE_CACHE_CLEANUP

log_handler 3 "Verbosity set to $VERBOSITY"
log_handler 3 "State cache timeout: $STATE_CACHE_TIMEOUT seconds"
log_handler 3 "State cache cleanup threshold: $STATE_CACHE_CLEANUP seconds"

if [ -z "$MODE" ]; then
    MODE_LOWER=""
else
    MODE_LOWER=$(printf "%s" "$MODE" | tr '[:upper:]' '[:lower:]')
fi

log_handler 3 "SERVICE=$SERVICE, MODE=$MODE_LOWER"

if [ -z "$SERVICE" ] || [ -z "$MODE" ]; then
    show_interactive_notice
    cat << 'EOF' >&2

  USAGE:
    throwawaydeadd [<service> <mode>] [OPTIONS] [vrrp_args...]
    throwawaydeadd show w|c          - Display warranty or conditions
    throwawaydeadd flush             - Remove all cached state files
    throwawaydeadd install [PATH]    - Install to system (default:
                                       /usr/local/bin/keepalived/throwawaydeadd)
    throwawaydeadd uninstall [PATH]  - Uninstall from system
EOF
    exit 2
fi

readonly CONFIG_FILE MODE MODE_LOWER NAME PRIORITY SERVICE STATE TYPE

case "$MODE_LOWER" in
    check)
        if ! cleanup_state_files "$STATE_CACHE_CLEANUP"; then
            log_handler 2 "State cache cleanup reported errors"
        fi

        log_handler 3 "Checking service with cache timeout: $STATE_CACHE_TIMEOUT seconds"

        check_cached_state "$SERVICE" "$STATE_CACHE_TIMEOUT"
        _CACHE_RC=$?

        if [ "$_CACHE_RC" -eq 0 ]; then
            log_handler 3 "$SERVICE was found (cached)"
            exit 0
        elif [ "$_CACHE_RC" -eq 1 ]; then
            log_handler 2 "$SERVICE not found (cached)"
            exit 1
        fi

        log_handler 3 "Cache miss or invalid, performing live check"
        if command -v pgrep >/dev/null 2>&1; then
            if pgrep -x "$SERVICE" >/dev/null; then
                if ! update_state_file "$SERVICE" 0; then
                    log_handler 2 "Failed to update cache state for $SERVICE"
                fi
                log_handler 3 "$SERVICE was found"
                exit 0
            else
                if ! update_state_file "$SERVICE" 1; then
                    log_handler 2 "Failed to update cache state for $SERVICE"
                fi
                log_handler 2 "$SERVICE not found"
                exit 1
            fi
        else
            log_handler 3 "pgrep command not found, falling back to killall -0"
            if killall -0 "$SERVICE" 2>/dev/null; then
                _EXIT_CODE=0
            else
                _EXIT_CODE=1
            fi
            if ! update_state_file "$SERVICE" "$_EXIT_CODE"; then
                log_handler 2 "Failed to update cache state for $SERVICE"
            fi
            log_handler 2 "$SERVICE check returned $_EXIT_CODE"
            exit "$_EXIT_CODE"
        fi
        ;;
    notify)
        if [ -z "$STATE" ]; then
            log_handler 1 "Missing VRRP state"
            exit 2
        fi
        IS_MASTER_RAW="${IS_MASTER:-false}"
        if check_is_true "$IS_MASTER_RAW"; then
            ROLE=MASTER
        else
            ROLE=BACKUP
        fi
        STATE_UPPER=$(printf "%s" "$STATE" | tr '[:lower:]' '[:upper:]')
        ROLE_UPPER=$(printf "%s" "$ROLE" | tr '[:lower:]' '[:upper:]')
        ACTION_KEY="${ROLE_UPPER}_IS_${STATE_UPPER}"
        ACTION="$(printenv "$ACTION_KEY")"
        if [ -z "$ACTION" ]; then
            ACTION="none"
        fi
        ACTION_LOWER=$(upper_to_lower "$ACTION")
        log_handler 2 "Role=$ROLE_UPPER, State=$STATE_UPPER, Action=$ACTION_LOWER"
        case "$ACTION_LOWER" in
            none)
                log_handler 3 "No action for $ACTION_KEY"
                ;;
            start|stop|restart|reload)
                log_handler 2 "Service action $ACTION_LOWER $SERVICE"
                if perform_service_action "$SERVICE" "$ACTION_LOWER"; then
                    log_handler 2 "Service $ACTION_LOWER succeeded for $SERVICE"
                else
                    log_handler 1 "Service $ACTION_LOWER failed for $SERVICE"
                    exit 1
                fi
                ;;
            *)
                log_handler 1 "Unknown action $ACTION for action key $ACTION_KEY"
                exit 1
                ;;
        esac
        log_handler 2 "$TYPE $NAME ($SERVICE) -> $STATE ($PRIORITY)"
        exit 0
        ;;
    *)
        log_handler 1 "Unknown throwawaydeadd script mode $MODE"
        exit 2
        ;;
esac
